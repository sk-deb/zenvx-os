#!/bin/sh
# ZenvX OS P1 session entrypoint — launches the Sway graphical desktop.
clear
printf '\n  Welcome to ZenvX OS P1 — starting the graphical desktop...\n\n'
# Software rendering so it works without a dedicated GPU (and inside QEMU).
export WLR_RENDERER=pixman
export WLR_NO_HARDWARE_CURSORS=1
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
exec sway
