# ZenvX OS P1 — Sway (tiling Wayland) configuration
set $mod Mod4
set $term foot

# --- look ---
output * bg #16161e solid_color
default_border pixel 2
gaps inner 6
gaps outer 4
font pango:DejaVu Sans Mono 11

client.focused          #7aa2f7 #1a1b26 #c0caf5 #7aa2f7 #7aa2f7
client.unfocused        #2a2e3a #16161e #a9b1d6 #2a2e3a #2a2e3a

# --- autostart: the ZenvX agent (first-boot setup, then the TUI) ---
exec $term sh -c 'zenvx; zenvx-tui; exec sh'

# --- keybindings ---
bindsym $mod+Return exec $term
bindsym $mod+d      exec wofi --show drun
bindsym $mod+q      kill
bindsym $mod+Shift+e exit
bindsym $mod+f      fullscreen
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
floating_modifier $mod normal

# --- status bar (ZenvX branded) ---
bar {
    position top
    status_command while echo "  ZenvX OS P1    $(date '+%a %d %b  %H:%M')    [Super+D launcher · Super+Enter term]"; do sleep 20; done
    colors {
        statusline #c0caf5
        background #1a1b26
        focused_workspace  #7aa2f7 #7aa2f7 #1a1b26
        inactive_workspace #2a2e3a #16161e #a9b1d6
    }
}
